# ══════════════════════════════════════════════════════════════
# Portkiro Frontend — Environment Variables
# ══════════════════════════════════════════════════════════════
# All VITE_* vars are embedded at build time by Vite.
# Copy this file to a local .env file (gitignored) or set in your hosting dashboard.
# ══════════════════════════════════════════════════════════════

# Backend API URL (defaults to http://localhost:5000/api)
# VITE_API_URL=http://localhost:5000/api

# EmailJS Credentials (optional — Contact form falls back to mailto: link if missing)
# Get these for free at https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
