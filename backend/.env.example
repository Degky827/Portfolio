# ══════════════════════════════════════════════════════════════════════════════
# Portkiro Backend — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values. The .env file is gitignored.
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/portfolio

# ──────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# JWT  (REQUIRED — no default)
# ──────────────────────────────────────────────
# WARNING: If JWT_SECRET is missing, jwt.sign() and jwt.verify() will throw.
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# 2FA / TOTP issuer name (used in authenticator apps)
# ──────────────────────────────────────────────
# TOTP_ISSUER=Portkiro Admin

# ──────────────────────────────────────────────
# Cloudinary (optional — falls back to local uploads)
# ──────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
