    {
      "_id": "6a38e9229206d4899f746582",
      "title": "LakeTana Tourist Management System",
      "slug": "laketana-tourist-management-system",
      "shortDescription": "A full-stack MERN marketplace platform empowering eco-tourism, local boat operator management, and historical monastery tour bookings around Lake Tana.",
      "fullDescription": "Built a robust, localized full-stack e-commerce and booking architecture tailored for regional tourism around Lake Tana, Ethiopia. The platform Bridges the gap between international travelers and local boat operators, offering real-time scheduling, dynamic tour package configurations, and automated reservation management.\n\nKey Engineering Milestones:\n• Designed an optimized MongoDB database schema handling relational references for tour routes, operator availability matrixes, and secure reservation logs.\n• Built a fully responsive frontend client featuring interactive routing maps, rich search filtering for historic island monasteries, and crisp modular dashboards for system administrators.\n• Engineered secure, atomic transaction handling logic with decoupled automated messaging triggers to streamline client-operator coordination.",
      "technologies": [
        "Next.js",
        "node.js",
        "express.js",
        "mongoDB"
      ],
      "githubUrl": "https://github.com/desalegnkasayemuluyekasaye-tech/LTTMS",
      "liveDemoUrl": "https://lttms-98vb.vercel.app/",
